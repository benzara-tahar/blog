---
import { type CollectionEntry, getCollection } from "astro:content";
import SocialList from "@/components/SocialList.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import Note from "@/components/note/Note.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

// Posts
const MAX_POSTS = 10;
const allPosts = await getAllPosts();
const allPostsByDate = allPosts
    .sort(collectionDateSort)
    .slice(0, MAX_POSTS) as CollectionEntry<"post">[];

// Notes
const MAX_NOTES = 5;
const allNotes = await getCollection("note");
const latestNotes = allNotes.sort(collectionDateSort).slice(0, MAX_NOTES);
---

<PageLayout meta={{ title: "Home" }}>
    <section>
        <h1 class="title mb-6">Hey, I'm Lahcene</h1>
        <p class="mb-4">
            A web developer passionate about modern frontend technologies and creating exceptional user experiences.
            I use this space to document my learning journey, share code snippets, and explore ideas about the evolving web.
        </p>
        <p class="mb-4">
            Currently diving deep into performance optimization, accessibility, and the latest JavaScript frameworks.
            Let's learn and build together!
        </p>
        <SocialList />
    </section>
    <section class="mt-16">
        <h2 class="title text-accent mb-6 text-xl"><a href="/posts/">Latest Posts</a></h2>
        <ul class="space-y-6" role="list">
            {
                allPostsByDate.map((p) => (
                    <li class="grid gap-2 sm:grid-cols-[auto_1fr]">
                        <PostPreview post={p} />
                    </li>
                ))
            }
        </ul>
    </section>
    {
        latestNotes.length > 0 && (
            <section class="mt-16">
                <h2 class="title text-accent mb-6 text-xl">
                    <a href="/notes/">Quick Notes & Snippets</a>
                </h2>
                <ul class="space-y-6" role="list">
                    {latestNotes.map((note) => (
                        <li>
                            <Note note={note} as="h3" isPreview />
                        </li>
                    ))}
                </ul>
            </section>
        )
    }
</PageLayout>
